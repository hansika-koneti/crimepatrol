# =============================================================================
# CrimePatrol — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- Application ---
APP_ENV=development                   # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# --- Admin Credentials (single-admin dashboard) ---
ADMIN_EMAIL=admin@crimepatrol.local
ADMIN_PASSWORD=changeme123

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crimepatrol
POSTGRES_USER=crimepatrol
POSTGRES_PASSWORD=crimepatrol_secret
DATABASE_URL=postgresql+asyncpg://crimepatrol:crimepatrol_secret@localhost:5432/crimepatrol

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# --- City Configuration ---
CITY_ADAPTER=chicago                  # chicago | generic_csv | nyc (future)
CITY_NAME=Chicago
CITY_BOUNDING_BOX=-87.94,41.64,-87.52,42.02   # min_lon,min_lat,max_lon,max_lat
CITY_TIMEZONE=America/Chicago

# --- Chicago Open Data ---
CHICAGO_DATA_PORTAL_URL=https://data.cityofchicago.org/resource/ijzp-q8t2.json
CHICAGO_DATA_APP_TOKEN=                         # optional, increases rate limit

# --- LLM (Google Gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash                   # free tier model

# --- Weather (Open-Meteo — no key required) ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# --- Traffic (TomTom) ---
TOMTOM_API_KEY=your-tomtom-api-key-here
TOMTOM_BASE_URL=https://api.tomtom.com/traffic/services/4

# --- Events (Ticketmaster) ---
TICKETMASTER_API_KEY=your-ticketmaster-api-key-here
TICKETMASTER_BASE_URL=https://app.ticketmaster.com/discovery/v2

# --- Holidays (Nager.Date — no key required) ---
NAGER_DATE_BASE_URL=https://date.nager.at/api/v3
HOLIDAY_COUNTRY_CODE=US

# --- Scheduler ---
SCHEDULER_BACKEND=apscheduler           # apscheduler | airflow (future)
ETL_CRON=0 * * * *                      # every hour
MONITORING_CRON=0 6 * * *               # daily 6am
DAILY_REPORT_CRON=0 7 * * *             # daily 7am

# --- ML ---
MODEL_REGISTRY_PATH=backend/ml/saved_models
FEATURE_SCHEMA_VERSION=v1
DRIFT_ALERT_THRESHOLD=0.2               # PSI threshold to flag retraining
ACCURACY_DECAY_THRESHOLD=0.05           # 5% drop triggers alert

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json                         # json | text
METRICS_ENABLED=true
